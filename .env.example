# ============================================================
# MongliAgent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Stellar Agent Wallet (the wallet that PAYS for services) ---
# Generate at https://laboratory.stellar.org/#account-creator?network=testnet
# Fund with XLM via Friendbot, add USDC trustline, get testnet USDC at xlm402.com
STELLAR_SECRET_KEY=S...
STELLAR_PUBLIC_KEY=G...
STELLAR_NETWORK=testnet

# --- Anthropic (used by orchestrator planner + service-summary) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Web Search (used by service-search) ---
# Get a free key at https://serpapi.com
SERPAPI_KEY=...

# --- Service Recipient Addresses ---
# Each service receives USDC payments at these Stellar addresses.
# For a local demo all three can be the same address (e.g. a second testnet wallet).
# Each address MUST have a USDC trustline:
#   Issuer: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
SERVICE_SEARCH_ADDRESS=G...
SERVICE_SUMMARY_ADDRESS=G...
SERVICE_DATA_ADDRESS=G...